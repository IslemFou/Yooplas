
{% extends "base.html.twig" %}


{% block body %}
    
<!-- Section 1:banniere -->
<section class="container-fluid mt-5" id="sectionBanniere">
  <div class="container-sm w-75">
    <h1 class="display-4 p-4 text-center">Découvrez <span class="text-yoopla-red">les activités</span> près de <span class="text-yoopla-blue">chez-vous</span> !</h1>
    <p class="fs-4 p-4"><span class="text-yoopla-red fw-bold">Yoopla</span> est un site de reservation des évènements, activités culturelles ou sportive.</p>
  </div>
  <div class="bloc-images mx-2 px-4 position-relative">
    <img src="assets/images/logo/cyclism-deco.svg" class="position-absolute bottom-0 start-10 translate-middle-x" style="width: 13rem;" alt="vecteurcyclisme">
    <img src="assets/images/art.jpg" class="mx-8" style="width: 13rem;" alt="image art">
    <img src="assets/images/dance.jpg" class="m-4" alt="image dance">
    <img src="assets/images/logo/basket-deco.svg" class="position-absolute top-0 end-0 translate-middle-x" style="width: 13rem;" alt="vecteurbasket">
    <img src="assets/images/girl.jpg" class="p-2" alt="image yoga">
    <img src="assets/images/ballet.jpg" class="mx-10" style="width: 13rem;" alt="image ballet">
  </div>
</section>
<!-- Catégories -->

{% if categories is defined and categories|length > 0 %}
  <div class="row gap-3 justify-content-center align-items-center m-5" id="buttonsColor">
    {% for category in categories %}
      <button class="btn rounded-5 px-4 mx-4 mt-2 fw-medium shadow-sm" style="color:{{ category.couleur }};" id="coloredButtons">
        {{ category.name }}
      </button>
    {% endfor %}
  </div>
{% endif %}

<!-- search bar -->
	<form method="POST" action="" title="Formulaire de recherche">
		<div class="container m-5 rounded-5 shadow p-2 mx-auto d-flex justify-content-around align-items-center w-75">

			<div class="form-floating border-0">
				<input type="search" name="city" class="form-control border-0" id="searchLocation" placeholder="Paris ..." aria-label="Lieu">
				<label for="searchLocation"><i class="bi bi-geo me-2"></i>Lieu souhaité</label>
			</div>
			<p class="fw-bold fs-5 text-yoopla-red">Ou</p>

			<div class="form-floating border-0">
				<input type="search" name="title" class="form-control border-0" id="searchEvent" placeholder="Activité, événement ..." aria-label="Événement">
				<label for="searchEvent"><i class="bi bi-balloon me-2"></i>Événement souhaité</label>
			</div>

			<div>
				<button type="submit" class="border-0 bg-transparent">
					<i class="bi bi-search-heart text-yoopla-red fs-3"></i>
				</button>
			</div>

		</div>
	</form>
  {# Résultat de la recherche #}
{% if searchResults is defined %}
    {% if searchResults is not empty %}
        <div class="container rounded-3 p-3">
            <h5 class="fw-medium text-center p-4">Résultats de recherche :</h5>
            {% for result in searchResults %}
                <p><strong>{{ result.title }}</strong> à <strong>{{ result.city }}</strong></p>
            {% endfor %}
        </div>
    {% else %}
        <div class="container p-3">
            <div class="alert alert-warning">Aucun résultat trouvé.</div>
        </div>
    {% endif %}
{% endif %}
	<!-- Résultat de recherche -->

<!-- Section 3: activités en cours-->
<section class="container" id="section-activites">
  <h5 class="text-yoopla-red fw-medium">Les activités en cours</h5>
  <h3>Nos incontournables</h3>

  <!-- Début carrousel  -->
  <div id="yooplaCarousel" class="carousel slide">
    <div class="carousel-inner">
      
{% if allEvents is empty %}
    <div class="alert alert-warning text-center">Aucun événement trouvé pour le moment.</div>
{% else %}
    {% set eventChunks = allEvents|batch(3) %}
    <div id="yooplaCarousel" class="carousel slide">
        <div class="carousel-inner">
            {% for chunk in eventChunks %}
                <div class="carousel-item {% if loop.first %}active{% endif %}">
                    <div class="row g-4 justify-content-center p-3" id="ThreeCardsCarousel">
                        {% for event in chunk %}
                            <div class="col-sm-12 col-md-6 col-lg-4 card rounded-4 shadow mx-2 p-0">
                                <img src="{{ asset('uploads/events/' ~ (event.photo is not empty ? event.photo : 'default-img/default_event.jpg')) }}"
                                     class="card-img-top rounded-top-4 img-fluid"
                                     style="height:18rem; object-fit: cover;"
                                     alt="{{ event.title }}">
                                <div class="card-body">

                                    {% for category in event.categories %}
                                <span class="badge mb-2 text-yoopla-blue rounded-pill p-2 fw-medium border align-self-start">
                                        {{ category.name }}
                                </span>
                                        {% endfor %}
                                    <p class="small text-muted mb-1"><i class="bi bi-geo"></i> {{ event.city }} {{ event.zipCode }}</p>
                                    <h5 class="card-title">{{ event.title }}</h5>
                                    <p class="card-text">{{  (event.description|length > 90 ? event.description[:90] ~ '...' : event.description)|raw }}</p>
                                </div>
                                <div class="mt-auto text-center">
                                    <a href="{{ path('app_event', { slug: event.slug }) }}"
                                       class="btn yoopla-primary fw-medium rounded-5 px-4 py-2 shadow mb-3">Voir plus</a>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endfor %}
        </div>

        {% if allEvents|length > 3 %}
            <button class="carousel-control-prev" type="button" data-bs-target="#yooplaCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#yooplaCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
        {% endif %}
    </div>
{% endif %}

  <!-- fin carousel -->

  <div class="container d-flex justify-content-center m-4">
    <a href="{{ path('event_index')}}" class="btn btn-yoopla-secondary-outlined rounded-5 px-5 py-3 fw-medium shadow-sm icon-link icon-link-hover position-relative">Afficher plus d'activités <i class="bi bi-arrow-right mx-3 position-absolute top-50 end-0 translate-middle-y"></i></a>
  </div>
</section>


{% endblock %}